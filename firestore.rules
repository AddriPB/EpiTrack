rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/epilepsyEvents/{eventId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/treatments/{treatmentId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
